# ============================================================================
# RAGS AI - Backend Environment Variables
# ============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Picovoice Wake Word (Required)
PICOVOICE_ACCESS_KEY=your_picovoice_access_key

# Whisper.cpp STT (Required)
WHISPER_CPP_PATH=/usr/local/bin/whisper
WHISPER_MODEL_PATH=/path/to/whisper.cpp/models/ggml-base.en.bin

# Ollama Local LLM (Required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ElevenLabs TTS (Optional - for better voice quality)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Gemini AI (Optional - for advanced features)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (Optional - for DALL-E, GPT-4)
OPENAI_API_KEY=your_openai_api_key

# Instagram API (Optional - for content posting)
INSTAGRAM_ACCESS_TOKEN=your_instagram_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id

# System Automation
ENABLE_SYSTEM_CONTROL=true
ENABLE_FILE_OPERATIONS=true
ENABLE_CAMERA=true
ENABLE_SCREEN_ACCESS=true

# Security
JWT_SECRET=your_jwt_secret_key_here
CORS_ORIGIN=http://localhost:1420,http://localhost:8081

# Logging
LOG_LEVEL=info

