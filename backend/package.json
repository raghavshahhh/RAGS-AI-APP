{
  "name": "rags-backend",
  "version": "1.0.0",
  "description": "RAGS AI - Backend API with Voice Pipeline",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "rags": "tsx src/start-rags.ts",
    "test": "jest",
    "test:voice": "tsx src/test-voice-pipeline.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "ai",
    "voice",
    "assistant",
    "ollama",
    "whisper",
    "picovoice"
  ],
  "author": "RAGS AI",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mediapipe/face_detection": "^0.4.1646425229",
    "@picovoice/porcupine-node": "^3.0.1",
    "@picovoice/pvrecorder-node": "^1.2.2",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "ollama": "^0.6.2",
    "puppeteer": "^24.29.1",
    "socket.io": "^4.8.1",
    "tesseract.js": "^6.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
